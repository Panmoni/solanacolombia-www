{
  "name": "solanacolombia-www",
  "type": "module",
  "version": "0.1.2",
  "scripts": {
    "dev": "npm run db:pull && astro dev",
    "db:pull": "wrangler d1 export solana_builders --remote --output ./prod_dump.sql && rm -rf .wrangler/state/v3/d1 && wrangler d1 execute solana_builders --local --file=./prod_dump.sql && rm ./prod_dump.sql",
    "build": "astro build",
    "preview": "astro build && wrangler dev",
    "deploy": "astro build && wrangler deploy",
    "astro": "astro",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format .",
    "format:write": "biome format --write .",
    "check": "ultracite check",
    "fix": "ultracite fix",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{js,ts}": [
      "biome format --write",
      "biome check --write"
    ],
    "*.astro": [
      "biome check --write"
    ],
    "*.{json,jsonc,css}": [
      "biome format --write"
    ]
  },
  "engines": {
    "node": ">=24.0.0"
  },
  "dependencies": {
    "@astrojs/cloudflare": "^13.1.8",
    "@cloudflare/workers-types": "^4.20260409.1",
    "@tailwindcss/vite": "^4.1.18",
    "astro": "^6.1.5",
    "resend": "^6.10.0",
    "tailwindcss": "^4.1.18",
    "uuid": "^13.0.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.11",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "ultracite": "^7.4.4",
    "wrangler": "^4.81.1"
  }
}
